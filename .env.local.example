# Copy to .env.local and adjust. Never commit .env.local.

# --- Clerk (if used for login in this app) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# =============================================================================
# Default: real Build AI API (v1 gateway)
# =============================================================================
# NEXT_PUBLIC_BACKEND_API_URL=https://localhost.api.build.ai:8000
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v1
# NEXT_PUBLIC_OPS_SKIP_AUTH=false
# NEXT_PUBLIC_MOCK_OPS_API=false

# =============================================================================
# Ops v2 HTTP mock (see docs/ops-v2-mock-api.md)
# Run mock from Build AI monorepo: apps/buildai-api → uvicorn api.mock_main:app --port 8765
# =============================================================================
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8765
NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v2
NEXT_PUBLIC_OPS_SKIP_AUTH=true
# Required: do not use in-memory mock when hitting the real HTTP mock server
NEXT_PUBLIC_MOCK_OPS_API=false

# =============================================================================
# In-memory mock only (no Python server) — NEXT dev on localhost
# =============================================================================
# NEXT_PUBLIC_MOCK_OPS_API=true
# NEXT_PUBLIC_OPS_SKIP_AUTH=true
