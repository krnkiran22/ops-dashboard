# Copy to .env.local and adjust. Never commit .env.local.

# --- Clerk (if used for login in this app) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# =============================================================================
# Default (committed): Ops API via ngrok tunnel — see src/lib/api/client.ts
# Override NEXT_PUBLIC_BACKEND_API_URL when the tunnel hostname changes.
# =============================================================================
# (no vars required — client defaults to the tunnel URL)

# Optional overrides:
# NEXT_PUBLIC_BACKEND_API_URL=https://garnetlike-mara-coadunate.ngrok-free.dev
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v1
# NEXT_PUBLIC_OPS_SKIP_AUTH=false
# NEXT_PUBLIC_MOCK_OPS_API=false

# =============================================================================
# Local Build AI gateway (no ngrok)
# =============================================================================
# NEXT_PUBLIC_BACKEND_API_URL=https://localhost.api.build.ai:8000
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v1

# =============================================================================
# Ops v2 HTTP mock on :8765 (see docs/ops-v2-mock-api.md)
# =============================================================================
# NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8765
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v2
# NEXT_PUBLIC_OPS_SKIP_AUTH=true
# NEXT_PUBLIC_MOCK_OPS_API=false

# =============================================================================
# In-memory fixtures only (no HTTP) — NEXT dev on localhost
# =============================================================================
# NEXT_PUBLIC_MOCK_OPS_API=true
# NEXT_PUBLIC_OPS_SKIP_AUTH=true
