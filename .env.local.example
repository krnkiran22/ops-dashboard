# Copy to `.env.local`. Never commit `.env.local`.

# =============================================================================
# Ops v2 mock API (local) — Python uvicorn on :8765, path prefix `/v2/ops`
# =============================================================================
# NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8765
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v2
# NEXT_PUBLIC_OPS_SKIP_AUTH=true
# NEXT_PUBLIC_MOCK_OPS_API=false

# =============================================================================
# ngrok / remote tunnel (fixes browser CORS when the dashboard is on another origin)
# =============================================================================
# Set your current tunnel URL (no trailing slash):
# NEXT_PUBLIC_BACKEND_API_URL=https://YOUR-SUBDOMAIN.ngrok-free.app
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v2
# NEXT_PUBLIC_OPS_SKIP_AUTH=true
# NEXT_PUBLIC_MOCK_OPS_API=false
#
# Required for Vercel (or any https:// origin) so the browser does not call ngrok directly:
# NEXT_PUBLIC_OPS_SAME_ORIGIN_PROXY=true

# =============================================================================
# Build AI gateway (TLS / prod-style) — use v2 ops routes unless the host is v1-only
# =============================================================================
# NEXT_PUBLIC_BACKEND_API_URL=https://localhost.api.build.ai:8000
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v2
# Legacy only:
# NEXT_PUBLIC_OPS_API_GATEWAY_VERSION=v1

# =============================================================================
# In-memory fixtures only (no HTTP) — local dev on localhost / LAN without env
# =============================================================================
# NEXT_PUBLIC_MOCK_OPS_API=true
# NEXT_PUBLIC_OPS_SKIP_AUTH=true

# --- Clerk (optional) ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
